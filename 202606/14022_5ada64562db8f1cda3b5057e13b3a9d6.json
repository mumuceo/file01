[
  {
    "bookSourceName": "Wikipedia（知识+书籍背景）",
    "bookSourceType": 0,
    "bookSourceUrl": "https://www.wikipedia.org/",
    "searchUrl": "https://en.wikipedia.org/w/api.php?action=opensearch&search={{key}}&limit=10&format=json",
    "ruleSearch": {
      "bookList": "$.1[*]",
      "name": "",
      "bookUrl": "$.3[*]"
    },
    "enabled": true
  },

  {
    "bookSourceName": "Internet Archive（电子书库PDF/EPUB）",
    "bookSourceType": 0,
    "bookSourceUrl": "https://archive.org/",
    "searchUrl": "https://archive.org/advancedsearch.php?q={{key}}&output=json&rows=20",
    "ruleSearch": {
      "bookList": "$.response.docs[*]",
      "name": "title",
      "bookUrl": "identifier"
    },
    "enabled": true
  },

  {
    "bookSourceName": "Project Gutenberg（经典英文小说）",
    "bookSourceType": 0,
    "bookSourceUrl": "https://www.gutenberg.org/",
    "searchUrl": "https://www.gutenberg.org/ebooks/search/?query={{key}}",
    "ruleSearch": {
      "bookList": "//li[@class='booklink']",
      "name": ".//span[@class='title']/text()",
      "bookUrl": ".//a/@href"
    },
    "enabled": true
  },

  {
    "bookSourceName": "Standard Ebooks（高质量英文小说）",
